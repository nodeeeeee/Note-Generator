{
  "name": "auto-note",
  "version": "0.9.26",
  "description": "AutoNote — lecture notes generator from Canvas recordings",
  "homepage": "https://github.com/nodeeeeee/Auto-Note",
  "author": {
    "name": "nodeeeeee",
    "email": "autonote@users.noreply.github.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "test": "jest test/",
    "build-linux": "electron-builder --linux",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.autonote.app",
    "productName": "AutoNote",
    "files": [
      "**/*",
      "!node_modules/**/*.md",
      "!test/**"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "../assets/icon.png",
      "category": "Education",
      "desktop": {
        "Name": "AutoNote",
        "Comment": "Lecture notes generator from Canvas recordings",
        "StartupWMClass": "AutoNote"
      }
    },
    "win": {
      "target": "nsis",
      "icon": "../assets/icon.ico"
    },
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AutoNote"
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      "icon": "../assets/icon.icns"
    },
    "extraResources": [
      {
        "from": "../downloader.py",
        "to": "scripts/downloader.py"
      },
      {
        "from": "../extract_caption.py",
        "to": "scripts/extract_caption.py"
      },
      {
        "from": "../frame_extractor.py",
        "to": "scripts/frame_extractor.py"
      },
      {
        "from": "../semantic_alignment.py",
        "to": "scripts/semantic_alignment.py"
      },
      {
        "from": "../alignment_parser.py",
        "to": "scripts/alignment_parser.py"
      },
      {
        "from": "../note_generation.py",
        "to": "scripts/note_generation.py"
      }
    ]
  }
}
